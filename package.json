{
  "name": "claude-squad",
  "version": "0.1.0",
  "description": "Terminal dashboard for monitoring Claude Code agent sessions",
  "type": "module",
  "bin": {
    "claude-squad": "./dist/bin/cli.js"
  },
  "scripts": {
