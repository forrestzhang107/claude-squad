    "cli",
    "terminal",
    "dashboard",
    "agent"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^18.3.12",
    "typescript": "^5.7.0"
  }
}
